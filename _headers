# Cache most stuff as public for 1 week
# We don't cache the HTML so that if it changes we revalidate (even if we don't transfer it)
# It looks like CF pages supports the same syntax: https://developers.cloudflare.com/pages/platform/headers/
/*.svg
    Cache-Control: max-age=604800
/*.ico
    Cache-Control: max-age=604800
/*.js
    Cache-Control: max-age=604800
/*.css
    Cache-Control: max-age=604800
/*.jpg
    Cache-Control: max-age=604800
/*.gif
    Cache-Control: max-age=604800
# Require HTTPS for all requests to this domain for 1 year
# We also set a Content-Security-Policy to only allow resources from the same origin, which helps prevent XSS attacks
/*
    Strict-Transport-Security: max-age=31536000
    Content-Security-Policy: default-src 'self'; style-src 'self' 'unsafe-inline'